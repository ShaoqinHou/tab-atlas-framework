{
  "name": "tab-atlas-framework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "eval:semantic": "tsx scripts/eval-semantic.ts",
    "eval:agent": "tsx scripts/eval-agent.ts --provider codex",
    "eval:agent:stub": "tsx scripts/eval-agent.ts --provider stub",
    "eval:security": "tsx scripts/eval-security.ts",
    "eval:privacy": "tsx scripts/eval-privacy.ts",
    "eval:onboarding": "tsx scripts/eval-onboarding.ts",
    "eval:retrieval": "tsx scripts/eval-retrieval.ts",
    "eval:review": "tsx scripts/eval-review.ts",
    "eval:workspace-ux": "tsx scripts/eval-workspace-ux.ts",
    "eval:runtime-safety": "tsx scripts/eval-runtime-safety.ts",
    "eval:action-lifecycle": "tsx scripts/eval-action-lifecycle.ts",
    "eval:pilot-readiness": "tsx scripts/eval-pilot-readiness.ts",
    "environment:clone": "tsx scripts/environment-clone.ts",
    "roleplay:prehuman": "tsx scripts/roleplay-prehuman.ts",
    "runtime:inspect": "tsx scripts/runtime-inspect.ts",
    "runtime:remediate-bootstrap": "tsx scripts/runtime-remediate-bootstrap.ts",
