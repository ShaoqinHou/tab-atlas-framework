{
  "name": "tab-atlas-framework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "eval:semantic": "tsx scripts/eval-semantic.ts",
    "eval:agent": "tsx scripts/eval-agent.ts --provider codex",
    "eval:agent:stub": "tsx scripts/eval-agent.ts --provider stub",
    "eval:security": "tsx scripts/eval-security.ts",
    "eval:privacy": "tsx scripts/eval-privacy.ts",
    "eval:onboarding": "tsx scripts/eval-onboarding.ts",
    "import": "tsx scripts/import-snapshot.ts",
    "scan:codex": "tsx scripts/scan-codex.ts",
    "smoke:codex": "tsx scripts/smoke-codex.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@openai/codex-sdk": "latest",
    "better-sqlite3": "latest",
    "commander": "latest",
    "fastify": "latest",
    "jsdom": "^29.1.1",
    "nanoid": "latest",
    "undici": "^7.28.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "latest",
    "@types/jsdom": "^28.0.3",
    "@types/node": "latest",
    "eslint": "latest",
    "globals": "^17.6.0",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.61.1",
    "vitest": "latest"
  }
}
