    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "latest",
    "@types/jsdom": "^28.0.3",
    "@types/node": "latest",
    "eslint": "latest",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.61.1",
    "vitest": "latest"
